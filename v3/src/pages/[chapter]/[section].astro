---
import Layout from '../../layouts/Layout.astro';
import data from '../../data.js';
import { title as siteTitle } from '../../meta.js';

export function getStaticPaths() {
  const paths: any[] = [];
  data.forEach((chapter: any) => {
    chapter.content.forEach((section: any) => {
      paths.push({
        params: { chapter: chapter.slug, section: section.slug },
        props: { chapter, section },
      });
    });
  });
  return paths;
}

const { chapter, section } = Astro.props;
const pageTitle = `${section.title} - ${siteTitle}`;

function countWords(paragraphs: string[]) {
  return paragraphs.reduce((total: number, p: string) => total + p.split(' ').length, 0);
}

const readingTime = Math.round(countWords(section.content) / 200 + 1) + ' dakika';

// Truncate description to ~155 chars for meta
const rawDesc = section.content[0] || '';
const metaDescription = rawDesc.length > 155 ? rawDesc.slice(0, 152) + '...' : rawDesc;
---

<Layout title={pageTitle} description={metaDescription}>
  <article>
    <div class="card">
      <div class="p-3">
        <nav aria-label="Breadcrumb">
          <a href={`/${chapter.slug}`} class="text-sm mb-5 block hover:underline">&larr; {chapter.title}</a>
        </nav>
        <h1 class="section-title">{section.title}</h1>
      </div>
    </div>
    <p class="reading-time">Okuma süresi: {readingTime}</p>
    {section.content.map((p: string) => (
      <p class="section-paragraph">{p}</p>
    ))}
  </article>
</Layout>

---
import StoreButton from './StoreButton.astro';
---

<div class="card mb-10">
  <div class="relative flex flex-col justify-center">
    <div class="banner-card-header w-full px-4">
      <span class="font-bold text-white text-2xl tracking-normal">
        cepte ilmihal oku!
      </span>
    </div>
    <div class="banner-card-body">
      <img
        src="/android-bg.jpg"
        style="object-fit: cover; width: 100%; height: 66px;"
        alt="Google Play Store background image"
      />
    </div>
  </div>
  <div class="p-4">
    <div class="flex flex-col gap-3">
      <div class="text-center">
        <p>
          <span class="font-bold bg-gray-700/50 text-white p-0.5 px-1 rounded">
            ilmihal oku
          </span>{" "}
          uygulamasını App Store veya Google Play Store'dan cihazınıza
          indirebilirsiniz.
        </p>
      </div>
      <div class="flex justify-center gap-2 flex-col sm:flex-row items-center">
        <StoreButton
          link="https://apps.apple.com/us/app/ilmihaloku-com/id1664334763"
          icon="ri-apple-fill"
          label="App Store"
        />
        <StoreButton
          link="https://play.google.com/store/apps/details?id=com.oku.ilmihal"
          icon="ri-google-play-fill"
          label="Google Play Store"
        />
      </div>
    </div>
  </div>
</div>
